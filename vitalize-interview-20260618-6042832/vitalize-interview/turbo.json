{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": ["DATABASE_URL"],
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**"],
      "env": ["DATABASE_URL"]
    },
    "start": {},
    "type-check": {},
    "lint": {},
    "dev": {
      "cache": false,
      "persistent": true,
      "env": ["DATABASE_URL"]
    },
    "test": {},
    "generate": {},
    "drop": {},
    "migrate": {
      "cache": false
    },
    "seed": {
      "cache": false
    },
    "studio": {}
  }
}
