{
  "name": "vitalize-interview",
  "devDependencies": {
    "@effect/language-service": "^0.82.0",
    "dotenv-cli": "^8.0.0",
    "eslint": "^8.57.1",
    "prettier": "^3.6.2",
    "turbo": "^2.6.1"
  },
  "packageManager": "bun@1.3.2",
  "private": true,
  "scripts": {
    "build": "dotenv -- turbo run build",
    "start": "dotenv -- turbo run start",
    "setup": "./setup.sh",
    "dev": "dotenv -- turbo run dev studio",
    "type-check": "dotenv -- turbo run type-check",
    "lint": "dotenv -- turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "test": "dotenv -- turbo run test",
    "generate": "dotenv -- turbo run generate",
    "drop": "dotenv -- turbo run drop",
    "migrate": "dotenv -- turbo run migrate",
    "seed": "dotenv -- turbo run seed",
    "studio": "dotenv -- turbo run studio"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {}

}
